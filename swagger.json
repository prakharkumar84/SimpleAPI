{
  "openapi": "3.0.3",
  "info": {
    "title": "API Training Sandbox",
    "description": "A one-stop REST API for learning and testing all common HTTP methods, parameter types, authentication patterns, and response scenarios.",
    "version": "1.0.0",
    "contact": {
      "name": "Prakhar Kumar"
    }
  },
  "servers": [
    {
      "url": "https://simpleapi-vq4c.onrender.com",
      "description": "Production (Render)"
    },
    {
      "url": "http://localhost:3000",
      "description": "Local development"
    }
  ],
  "paths": {
    "/api/products": {
      "get": {
        "summary": "Get all products",
        "tags": ["Products"],
        "responses": {
          "200": {
            "description": "List of all products",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer", "example": 5 },
                    "data": {
                      "type": "array",
                      "items": { "$ref": "#/components/schemas/Product" }
                    }
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "summary": "Create a new product",
        "tags": ["Products"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "category", "price"],
                "properties": {
                  "name": { "type": "string", "example": "Keyboard" },
                  "category": { "type": "string", "example": "electronics" },
                  "price": { "type": "number", "example": 79.99 },
                  "inStock": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Product created successfully" },
          "400": { "description": "Validation failed - missing required fields" }
        }
      }
    },
    "/api/products/search": {
      "get": {
        "summary": "Search/filter products with query parameters",
        "tags": ["Products"],
        "parameters": [
          { "name": "name", "in": "query", "schema": { "type": "string" }, "description": "Filter by product name (partial match)" },
          { "name": "category", "in": "query", "schema": { "type": "string", "enum": ["electronics", "furniture", "stationery"] }, "description": "Filter by category" },
          { "name": "minPrice", "in": "query", "schema": { "type": "number" }, "description": "Minimum price" },
          { "name": "maxPrice", "in": "query", "schema": { "type": "number" }, "description": "Maximum price" },
          { "name": "inStock", "in": "query", "schema": { "type": "string", "enum": ["true", "false"] }, "description": "Filter by stock status" }
        ],
        "responses": {
          "200": {
            "description": "Filtered product list",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "filters": { "type": "object" },
                    "count": { "type": "integer" },
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/products/{id}": {
      "get": {
        "summary": "Get product by ID (path parameter)",
        "tags": ["Products"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "Product ID (1-5)" }
        ],
        "responses": {
          "200": { "description": "Product found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/Product" } } } },
          "404": { "description": "Product not found" }
        }
      },
      "put": {
        "summary": "Full update - replace product (all fields required)",
        "tags": ["Products"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["name", "category", "price"],
                "properties": {
                  "name": { "type": "string", "example": "Gaming Laptop" },
                  "category": { "type": "string", "example": "electronics" },
                  "price": { "type": "number", "example": 1499.99 },
                  "inStock": { "type": "boolean", "example": true }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Product fully updated" },
          "400": { "description": "Missing required fields" },
          "404": { "description": "Product not found" }
        }
      },
      "patch": {
        "summary": "Partial update - update only specified fields",
        "tags": ["Products"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "category": { "type": "string" },
                  "price": { "type": "number", "example": 899.99 },
                  "inStock": { "type": "boolean" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Product partially updated" },
          "404": { "description": "Product not found" }
        }
      },
      "delete": {
        "summary": "Delete a product",
        "tags": ["Products"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" } }
        ],
        "responses": {
          "200": { "description": "Product deleted" },
          "404": { "description": "Product not found" }
        }
      }
    },
    "/api/users": {
      "get": {
        "summary": "Get all users",
        "tags": ["Users"],
        "responses": {
          "200": {
            "description": "List of all users",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "count": { "type": "integer" },
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/User" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/users/{id}": {
      "get": {
        "summary": "Get user by ID",
        "tags": ["Users"],
        "parameters": [
          { "name": "id", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "User ID (1-3)" }
        ],
        "responses": {
          "200": { "description": "User found", "content": { "application/json": { "schema": { "$ref": "#/components/schemas/User" } } } },
          "404": { "description": "User not found" }
        }
      }
    },
    "/api/secure/profile": {
      "get": {
        "summary": "Get profile (requires API key header)",
        "tags": ["Authentication"],
        "security": [{ "ApiKeyAuth": [] }],
        "parameters": [
          { "name": "x-api-key", "in": "header", "required": true, "schema": { "type": "string" }, "description": "API key: my-secret-key-123" }
        ],
        "responses": {
          "200": { "description": "Access granted - profile data returned" },
          "401": { "description": "Unauthorized - missing or invalid API key" }
        }
      }
    },
    "/api/headers/echo": {
      "get": {
        "summary": "Echo all request headers back (debugging tool)",
        "tags": ["Utilities"],
        "responses": {
          "200": { "description": "All request headers echoed back as JSON" }
        }
      }
    },
    "/api/validate": {
      "post": {
        "summary": "Validate plain text body",
        "tags": ["Validation"],
        "requestBody": {
          "required": true,
          "content": {
            "text/plain": {
              "schema": { "type": "string", "example": "Hello World" }
            }
          }
        },
        "responses": {
          "200": { "description": "Valid input" },
          "400": { "description": "Invalid input - body must be a non-empty string" }
        }
      }
    },
    "/api/validate-json": {
      "post": {
        "summary": "Validate JSON structure (id, name, email)",
        "tags": ["Validation"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["id", "name"],
                "properties": {
                  "id": { "type": "string", "example": "ABC123" },
                  "name": { "type": "string", "example": "Test User" },
                  "email": { "type": "string", "example": "test@example.com" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Validation passed" },
          "400": { "description": "Validation failed with details" }
        }
      }
    },
    "/api/login": {
      "post": {
        "summary": "Login and receive a fake JWT token",
        "tags": ["Authentication"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["username", "password"],
                "properties": {
                  "username": { "type": "string", "example": "admin" },
                  "password": { "type": "string", "example": "password123" }
                }
              }
            }
          }
        },
        "responses": {
          "200": { "description": "Login successful - token returned" },
          "400": { "description": "Missing username or password" },
          "401": { "description": "Invalid credentials (hint: admin / password123)" }
        }
      }
    },
    "/api/orders": {
      "post": {
        "summary": "Create order (query param + JSON body combined)",
        "tags": ["Orders"],
        "parameters": [
          { "name": "userId", "in": "query", "required": true, "schema": { "type": "integer" }, "description": "User ID placing the order" }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["productId", "quantity"],
                "properties": {
                  "productId": { "type": "integer", "example": 2 },
                  "quantity": { "type": "integer", "example": 3 }
                }
              }
            }
          }
        },
        "responses": {
          "201": { "description": "Order created" },
          "400": { "description": "Missing userId query param or body fields" }
        }
      }
    },
    "/api/paginated": {
      "get": {
        "summary": "Pagination example",
        "tags": ["Utilities"],
        "parameters": [
          { "name": "page", "in": "query", "schema": { "type": "integer", "default": 1 }, "description": "Page number" },
          { "name": "limit", "in": "query", "schema": { "type": "integer", "default": 2 }, "description": "Items per page" }
        ],
        "responses": {
          "200": {
            "description": "Paginated results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "page": { "type": "integer" },
                    "limit": { "type": "integer" },
                    "totalItems": { "type": "integer" },
                    "totalPages": { "type": "integer" },
                    "data": { "type": "array", "items": { "$ref": "#/components/schemas/Product" } }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/slow": {
      "get": {
        "summary": "Simulated slow response (timeout testing)",
        "tags": ["Utilities"],
        "parameters": [
          { "name": "delay", "in": "query", "schema": { "type": "integer", "default": 3000 }, "description": "Delay in milliseconds (max 10000)" }
        ],
        "responses": {
          "200": { "description": "Delayed response with timestamp" }
        }
      }
    },
    "/api/status/{code}": {
      "get": {
        "summary": "Return any HTTP status code (for testing error handling)",
        "tags": ["Utilities"],
        "parameters": [
          { "name": "code", "in": "path", "required": true, "schema": { "type": "integer" }, "description": "HTTP status code to return (100-599)" }
        ],
        "responses": {
          "default": { "description": "Returns the requested status code" }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Product": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Laptop" },
          "category": { "type": "string", "example": "electronics" },
          "price": { "type": "number", "example": 999.99 },
          "inStock": { "type": "boolean", "example": true }
        }
      },
      "User": {
        "type": "object",
        "properties": {
          "id": { "type": "integer", "example": 1 },
          "name": { "type": "string", "example": "Alice Johnson" },
          "email": { "type": "string", "example": "alice@example.com" },
          "role": { "type": "string", "enum": ["admin", "user"], "example": "admin" }
        }
      }
    },
    "securitySchemes": {
      "ApiKeyAuth": {
        "type": "apiKey",
        "in": "header",
        "name": "x-api-key",
        "description": "Use value: my-secret-key-123"
      }
    }
  }
}
